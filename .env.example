# --- Next.js (build + runtime via Docker Compose or Vercel) ---
# Canonical URL — baked into the client bundle at build time — must match production URL on Vercel
NEXT_PUBLIC_SITE_URL=https://postrockag.com

NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=https://www.google.com/maps/d/embed?mid=1Vuj6vzVl1PkG3AGrU27LN9i9xfNNL14&ehbc=2E312F&noprof=1
NEXT_PUBLIC_CONTACT_TO_EMAIL=

# Sanity CMS (`/studio` + SSR). Omit project ID for local fallback copy only.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Server-only secrets (never prefix with NEXT_PUBLIC_)
RESEND_API_KEY=
CONTACT_FROM_EMAIL=
CONTACT_TO_EMAIL=info@postrockag.com
INVESTOR_TO_EMAIL=investors@postrockag.com

MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
MAILCHIMP_DC=us21
