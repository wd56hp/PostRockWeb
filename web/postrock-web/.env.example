# Canonical site URL — used for metadata, JSON-LD URLs, and next-sitemap at build time
NEXT_PUBLIC_SITE_URL=https://postrockag.com

# Sanity CMS — `NEXT_PUBLIC_*` required for embedded Studio (`/studio`) and browser-side helpers.
# Omit both to build with local fallback copy only (read API stays disabled).
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Optional embedded HQ map iframe URL (Google Maps “Embed” link)
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=https://www.google.com/maps/d/embed?mid=1Vuj6vzVl1PkG3AGrU27LN9i9xfNNL14&ehbc=2E312F&noprof=1

# Optional fallback shown to browsers if CONTACT_TO_EMAIL is not set server-side
NEXT_PUBLIC_CONTACT_TO_EMAIL=

# Resend — server-only API key for transactional mail
RESEND_API_KEY=

# Verified sender domain in Resend (defaults to onboarding@resend.dev if unset)
CONTACT_FROM_EMAIL=

CONTACT_TO_EMAIL=info@postrockag.com
INVESTOR_TO_EMAIL=investors@postrockag.com

# Mailchimp Marketing API — server-only (newsletter + tagged interest lists)
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
# Datacenter suffix from your Mailchimp API key (e.g. us21)
MAILCHIMP_DC=us21
